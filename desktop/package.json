{
  "name": "private-domain-assistant-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "typecheck": "vue-tsc --noEmit && tsc -p tsconfig.main.json --noEmit",
    "build": "vite build && tsc -p tsconfig.main.json",
    "dev": "vite --host 127.0.0.1",
    "electron:dev": "npm run build && set VITE_DEV_SERVER_URL=http://127.0.0.1:5173&& electron .",
    "electron:preview": "npm run build && electron .",
    "electron:smoke": "npm run build && node scripts/electron-smoke.mjs",
    "renderer:smoke": "npm run build && node scripts/renderer-smoke.mjs"
  },
  "dependencies": {
    "electron": "^31.7.7",
    "vue": "^3.5.17"
  },
  "devDependencies": {
    "@types/node": "^20.19.4",
    "@vitejs/plugin-vue": "^5.2.4",
    "typescript": "^5.5.4",
    "vite": "^5.4.19",
    "vue-tsc": "^2.2.10"
  }
}
