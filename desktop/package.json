{
  "name": "private-domain-assistant-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "typecheck": "vue-tsc --noEmit && tsc -p tsconfig.main.json --noEmit",
    "build": "vite build && tsc -p tsconfig.main.json",
    "dev": "vite --host 127.0.0.1",
    "electron:dev": "npm run build && set VITE_DEV_SERVER_URL=http://127.0.0.1:5173&& electron .",
    "electron:preview": "npm run build && electron .",
    "electron:smoke": "npm run build && node scripts/electron-smoke.mjs",
    "renderer:smoke": "npm run build && node scripts/renderer-smoke.mjs",
    "package:dir": "npm run build && node scripts/package-dir.mjs",
    "package:verify": "npm run package:dir && node scripts/package-verify.mjs"
  },
  "build": {
    "extends": null
  },
  "dependencies": {
    "vue": "^3.5.17"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "@types/node": "^20.19.4",
    "@vitejs/plugin-vue": "^6.0.7",
    "electron": "^40.10.2",
    "electron-builder": "^26.15.3",
    "typescript": "^5.5.4",
    "vite": "^8.1.3",
    "vue-tsc": "^2.2.10"
  }
}
