# Private Domain Assistant production environment template
# Copy to the server as /opt/private-domain-assistant/config/production.env
# Fill real values on the server only. Do not commit real secrets.

APP_ENV=production
MOCK_EXTERNALS=false
SERVER_PORT=8080

SPRING_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/private_domain_assistant_prod?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
SPRING_DATASOURCE_USERNAME=pda_prod
SPRING_DATASOURCE_PASSWORD=change-me

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Must be replaced before production. Generate at least 32 random bytes.
SYSTEM_JWT_SECRET=change-me-in-production

VERSION_STORAGE_ROOT=/data/private-domain-assistant/uploads/desktop-releases
VERSION_PUBLIC_BASE_URL=/downloads/desktop-releases

# Optional JVM tuning for the systemd service.
JAVA_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC
